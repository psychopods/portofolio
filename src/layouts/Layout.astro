---
import '../styles/global.css';
import db from '../lib/db';

interface Props {
  title?: string;
  description?: string;
  isAdmin?: boolean;
}

let devName = "Paschal Joseph";
let devRole = "Systems Architect & Developer";
let titleVal = "Paschal Joseph | Systems Architect & Cross-Platform Developer";
let descVal = "Systems-focused Software Architect and Developer with expertise in Rust (Core Logic), Kotlin Multiplatform (KMP), distributed telemetry systems, and serial port hardware integrations.";
let projectsCount = 0;
let skillsCount = 0;
let contactGithub = "github.com/psychopods";

try {
  const settings = db.prepare('SELECT * FROM portfolio_settings').all() as { key: string, value: string }[];
  const settingsMap = new Map(settings.map(s => [s.key, s.value]));
  
  if (settingsMap.has('dev_name')) devName = settingsMap.get('dev_name')!;
  if (settingsMap.has('dev_role')) devRole = settingsMap.get('dev_role')!;
  if (settingsMap.has('hero_title')) {
    titleVal = `${devName} | ${settingsMap.get('hero_title')}`;
  }
  if (settingsMap.has('hero_description')) {
    descVal = settingsMap.get('hero_description')!;
  }
  if (settingsMap.has('contact_github')) {
    contactGithub = settingsMap.get('contact_github')!;
  }

  projectsCount = (db.prepare('SELECT COUNT(*) as count FROM projects').get() as { count: number }).count;
  skillsCount = (db.prepare('SELECT COUNT(*) as count FROM skills').get() as { count: number }).count;
} catch (err) {
  console.error("Layout DB query failed:", err);
}

const githubUsername = contactGithub.replace(/^(https?:\/\/)?(www\.)?github\.com\//i, '').split('/')[0] || 'developer';
const devNameFile = devName.toLowerCase().replace(/\s+/g, '_') + '_portfolio.rs';

const { 
  title = titleVal, 
  description = descVal,
  isAdmin = false 
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    
    <!-- Preload fonts to avoid layout shift -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body class="bg-[#0b0f19] text-[#e2e8f0] font-sans h-dvh flex flex-col overflow-hidden antialiased select-none">
    
    <!-- IDE Top Window Bar -->
    <header class="bg-[#0f1422] border-b ide-border h-11 min-h-11 flex items-center justify-between px-4 z-40">
      <!-- Left: Mac-style Window Controls -->
      <div class="flex items-center space-x-2 w-1/4">
        <span class="w-3 h-3 rounded-full bg-[#ef4444] inline-block opacity-80 hover:opacity-100 transition-opacity cursor-pointer"></span>
        <span class="w-3 h-3 rounded-full bg-[#f59e0b] inline-block opacity-80 hover:opacity-100 transition-opacity cursor-pointer"></span>
        <span class="w-3 h-3 rounded-full bg-[#10b981] inline-block opacity-80 hover:opacity-100 transition-opacity cursor-pointer"></span>
        <span class="ml-4 text-xs font-mono text-[#64748b] hidden md:inline-block">workspace/portfolio</span>
      </div>

      <!-- Center: IDE Search / Breadcrumb -->
      <div class="flex items-center justify-center w-2/4 max-w-md">
        <div id="palette-trigger" class="bg-[#090d16] border ide-border rounded px-3 py-1 flex items-center space-x-2 w-full text-xs font-mono text-[#64748b] cursor-pointer hover:bg-[#121826]/80 transition-colors select-none">
          <svg class="w-3.5 h-3.5 text-[#475569]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <span class="flex-grow text-center text-[#94a3b8] truncate">
            {isAdmin ? "admin_dashboard.rs" : devNameFile}
          </span>
          <span class="text-[10px] bg-[#1e293b] px-1 rounded text-[#475569]">⌘P</span>
        </div>
      </div>

      <!-- Right: Actions / Links -->
      <div class="flex items-center justify-end space-x-4 w-1/4">
        {isAdmin ? (
          <a href="/" class="text-xs font-mono bg-[#1e293b] hover:bg-[#334155] border ide-border px-3 py-1.5 rounded transition-all text-[#38bdf8] flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            View Portfolio
          </a>
        ) : (
          <a href="/admin" class="text-xs font-mono bg-[#1e293b] hover:bg-[#334155] border ide-border px-3 py-1.5 rounded transition-all text-[#f472b6] flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
            Admin Panel
          </a>
        )}
      </div>
    </header>

    <!-- Main Workspace Split Panel -->
    <div class="flex-grow flex overflow-hidden">
      <!-- Left sidebar: File Explorer -->
      <aside id="ide-sidebar" class="w-64 min-w-64 bg-[#0d121f] border-r ide-border flex flex-col justify-between hidden md:flex transition-transform duration-300">
        <div class="flex-grow overflow-y-auto">
          <!-- Workspace Title -->
          <div class="flex items-center justify-between px-4 py-2.5 border-b ide-border">
            <span class="text-xs font-bold font-mono tracking-wider text-[#94a3b8] uppercase">Project Explorer</span>
            <button class="text-[#475569] hover:text-[#94a3b8]">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
              </svg>
            </button>
          </div>

          <!-- Files Tree -->
          <nav class="p-2 font-mono text-sm">
            <div class="flex items-center space-x-1 py-1 text-[#64748b]">
              <svg class="w-4 h-4 text-amber-500 fill-current" viewBox="0 0 20 20">
                <path d="M2 6a2 2 0 012-2h5l2 2h5a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z" />
              </svg>
              <span class="font-bold text-[#94a3b8]">portfolio-workspace</span>
            </div>

            <!-- src folder -->
            <div class="pl-4">
              <div class="flex items-center space-x-1 py-1 text-[#64748b]">
                <svg class="w-4 h-4 text-amber-500 fill-current" viewBox="0 0 20 20">
                  <path d="M2 6a2 2 0 012-2h5l2 2h5a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z" />
                </svg>
                <span>src</span>
              </div>

              <!-- files within src -->
              <div class="pl-4 space-y-0.5">
                {isAdmin ? (
                  <>
                    <a href="/admin#dashboard" class="sidebar-file flex items-center space-x-2 px-2 py-1.5 rounded hover:bg-[#1a2333] text-[#38bdf8] border-l-2 border-transparent">
                      <span class="text-[#f59e0b] font-bold">⌥</span>
                      <span>dashboard.rs</span>
                    </a>
                    <a href="/admin#projects" class="sidebar-file flex items-center space-x-2 px-2 py-1.5 rounded hover:bg-[#1a2333] text-[#94a3b8] border-l-2 border-transparent">
                      <span class="text-[#38bdf8] font-bold">✏️</span>
                      <span>projects.json</span>
                    </a>
                    <a href="/admin#skills" class="sidebar-file flex items-center space-x-2 px-2 py-1.5 rounded hover:bg-[#1a2333] text-[#94a3b8] border-l-2 border-transparent">
                      <span class="text-[#a855f7] font-bold">⚙️</span>
                      <span>skills.db</span>
                    </a>
                    <a href="/admin#status" class="sidebar-file flex items-center space-x-2 px-2 py-1.5 rounded hover:bg-[#1a2333] text-[#94a3b8] border-l-2 border-transparent">
                      <span class="text-[#10b981] font-bold">⚡</span>
                      <span>status.log</span>
                    </a>
                  </>
                ) : (
                  <>
                    <a href="#hero" class="sidebar-file active flex items-center space-x-2 px-2 py-1.5 rounded bg-[#1e293b] text-[#38bdf8] border-l-2 border-[#38bdf8]">
                      <span class="text-orange-500 font-semibold">🦀</span>
                      <span>hero.rs</span>
                    </a>
                    <a href="#about" class="sidebar-file flex items-center space-x-2 px-2 py-1.5 rounded hover:bg-[#1a2333] text-[#94a3b8] border-l-2 border-transparent">
                      <span class="text-[#a855f7] font-semibold">🪆</span>
                      <span>about.kt</span>
                    </a>
                    <a href="#stack" class="sidebar-file flex items-center space-x-2 px-2 py-1.5 rounded hover:bg-[#1a2333] text-[#94a3b8] border-l-2 border-transparent">
                      <span class="text-yellow-500 font-semibold">⚡</span>
                      <span>stack.json</span>
                    </a>
                    <a href="#projects" class="sidebar-file flex items-center space-x-2 px-2 py-1.5 rounded hover:bg-[#1a2333] text-[#94a3b8] border-l-2 border-transparent">
                      <span class="text-[#10b981] font-semibold">🗄️</span>
                      <span>projects.db</span>
                    </a>
                    <a href="#contact" class="sidebar-file flex items-center space-x-2 px-2 py-1.5 rounded hover:bg-[#1a2333] text-[#94a3b8] border-l-2 border-transparent">
                      <span class="text-red-500 font-semibold">🐚</span>
                      <span>contact.sh</span>
                    </a>
                  </>
                )}
              </div>
            </div>
          </nav>
        </div>

        <!-- System Resources Indicator inside Sidebar -->
        <div class="p-4 border-t ide-border bg-[#0a0e19]">
          <div class="text-[11px] font-mono text-[#64748b] space-y-1.5">
            <div class="flex justify-between items-center">
              <span>Database:</span>
              <span class="text-[#10b981] flex items-center gap-1">
                <span class="w-1.5 h-1.5 rounded-full bg-[#10b981] animate-ping inline-block"></span>
                Connected
              </span>
            </div>
            <div class="flex justify-between items-center">
              <span>Target:</span>
              <span class="text-[#e2e8f0]">x86_64-linux-gnu</span>
            </div>
            <div class="flex justify-between items-center">
              <span>Mode:</span>
              <span class="text-orange-400">SSR Release</span>
            </div>
          </div>
        </div>
      </aside>

      <!-- Right Area: Tab Header + Editor Workspace -->
      <main class="flex-grow flex flex-col min-w-0 overflow-hidden bg-[#090d16]">
        
        <!-- Editor Tabs -->
        <div class="bg-[#0d121f] border-b ide-border h-9 min-h-9 flex items-center justify-between pr-4 select-none">
          <div class="flex overflow-x-auto no-scrollbar h-full">
            {isAdmin ? (
              <>
                <div class="bg-[#090d16] border-r ide-border border-t-2 border-[#38bdf8] px-4 py-2 text-xs font-mono text-[#e2e8f0] flex items-center space-x-2 cursor-pointer h-full">
                  <span class="text-[#f59e0b]">⌥</span>
                  <span>admin_dashboard.rs</span>
                  <span class="text-[#475569] hover:text-[#94a3b8] text-[9px]">✕</span>
                </div>
              </>
            ) : (
              <>
                <a href="#hero" class="tab-item bg-[#090d16] border-r ide-border border-t-2 border-[#38bdf8] px-4 py-2 text-xs font-mono text-[#e2e8f0] flex items-center space-x-2 cursor-pointer h-full relative group">
                  <span class="text-orange-500">🦀</span>
                  <span>hero.rs</span>
                  <span class="tab-close text-[#475569] hover:text-[#f43f5e] hover:bg-[#1e293b] px-0.5 rounded text-[8px] transition-colors ml-1" data-section="hero">✕</span>
                </a>
                <a href="#about" class="tab-item bg-[#0d121f] border-r ide-border border-t-2 border-transparent px-4 py-2 text-xs font-mono text-[#64748b] hover:text-[#94a3b8] flex items-center space-x-2 cursor-pointer h-full relative group">
                  <span class="text-[#a855f7]">🪆</span>
                  <span>about.kt</span>
                  <span class="tab-close text-[#475569] hover:text-[#f43f5e] hover:bg-[#1e293b] px-0.5 rounded text-[8px] transition-colors ml-1" data-section="about">✕</span>
                </a>
                <a href="#stack" class="tab-item bg-[#0d121f] border-r ide-border border-t-2 border-transparent px-4 py-2 text-xs font-mono text-[#64748b] hover:text-[#94a3b8] flex items-center space-x-2 cursor-pointer h-full relative group">
                  <span class="text-yellow-500">⚡</span>
                  <span>stack.json</span>
                  <span class="tab-close text-[#475569] hover:text-[#f43f5e] hover:bg-[#1e293b] px-0.5 rounded text-[8px] transition-colors ml-1" data-section="stack">✕</span>
                </a>
                <a href="#projects" class="tab-item bg-[#0d121f] border-r ide-border border-t-2 border-transparent px-4 py-2 text-xs font-mono text-[#64748b] hover:text-[#94a3b8] flex items-center space-x-2 cursor-pointer h-full relative group">
                  <span class="text-[#10b981]">🗄️</span>
                  <span>projects.db</span>
                  <span class="tab-close text-[#475569] hover:text-[#f43f5e] hover:bg-[#1e293b] px-0.5 rounded text-[8px] transition-colors ml-1" data-section="projects">✕</span>
                </a>
                <a href="#contact" class="tab-item bg-[#0d121f] border-r ide-border border-t-2 border-transparent px-4 py-2 text-xs font-mono text-[#64748b] hover:text-[#94a3b8] flex items-center space-x-2 cursor-pointer h-full relative group">
                  <span class="text-red-500">🐚</span>
                  <span>contact.sh</span>
                  <span class="tab-close text-[#475569] hover:text-[#f43f5e] hover:bg-[#1e293b] px-0.5 rounded text-[8px] transition-colors ml-1" data-section="contact">✕</span>
                </a>
              </>
            )}
          </div>

          <!-- Mobile Sidebar Toggle -->
          <button id="mobile-menu-btn" class="md:hidden text-[#94a3b8] hover:text-white p-1">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h8m-8 6h16" />
            </svg>
          </button>
        </div>

        <!-- Code Content Area -->
        <div id="editor-workspace" class="flex-grow overflow-y-auto relative scroll-smooth">
          <slot />
        </div>

        <!-- Collapsible Bottom Terminal Panel -->
        <div id="ide-terminal-panel" class="bg-[#0c101b] border-t ide-border h-36 md:h-48 flex flex-col hidden select-text">
          <!-- Terminal Header -->
          <div class="bg-[#0f1422] border-b ide-border h-8 min-h-8 flex items-center justify-between px-4 text-[11px] font-mono text-[#64748b]">
            <div class="flex items-center space-x-4">
              <span class="text-slate-300 font-bold border-b-2 border-[#38bdf8] pb-1 pt-0.5">Terminal</span>
              <span class="hover:text-slate-400 cursor-pointer pb-1 pt-0.5">Problems (0)</span>
              <span class="hover:text-slate-400 cursor-pointer pb-1 pt-0.5">Output</span>
              <span class="hover:text-slate-400 cursor-pointer pb-1 pt-0.5">Debug Console</span>
            </div>
            <button id="close-terminal-btn" class="text-[#475569] hover:text-[#e2e8f0] font-mono text-xs font-bold transition-colors">✕</button>
          </div>
          <!-- Terminal Body -->
          <div class="flex-grow p-3.5 font-mono text-xs overflow-y-auto bg-[#070a12] text-slate-300 space-y-1.5 leading-relaxed">
            <p class="text-slate-500">[system] Initializing telemetry serial socket connection on /dev/ttyUSB0...</p>
            <p class="text-emerald-500">[system] UART baudrate negotiated at 115200 bps. Telemetry stable.</p>
            <p class="text-sky-400">[system] Astro v6.4.4 compiler ready. Serving portfolio on http://localhost:4321</p>
            <p class="text-amber-500">[system] Database data.db successfully compiled and loaded with {projectsCount} projects & {skillsCount} skills.</p>
            <p class="text-slate-400">[system] Press <kbd class="px-1 bg-slate-800 border border-slate-700 rounded text-[10px] text-slate-300">Ctrl+P</kbd> or click the top search bar to launch the command palette.</p>
            <div class="flex items-center gap-1.5 text-slate-400 mt-2.5">
              <span class="text-emerald-400 font-bold">{githubUsername}@morta:~/portfolio$</span>
              <span class="w-1.5 h-3.5 bg-slate-400 animate-pulse inline-block"></span>
            </div>
          </div>
        </div>
      </main>
    </div>

    <!-- Command Palette Overlay -->
    <div id="command-palette" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-start justify-center pt-[15vh] hidden">
      <div class="bg-[#0d121f] border ide-border w-full max-w-lg rounded-lg shadow-2xl overflow-hidden font-mono text-sm">
        <div class="flex items-center gap-2.5 px-4 py-3 border-b ide-border bg-[#090d16]">
          <span class="text-sky-400 font-bold">></span>
          <input type="text" id="palette-search" placeholder="Type a command or file name..." class="bg-transparent border-none outline-none flex-grow text-slate-200 text-sm focus:ring-0 focus:outline-none placeholder-slate-500" />
          <span class="text-[10px] text-slate-500 bg-slate-800/80 border border-slate-700 px-1.5 py-0.5 rounded">ESC to close</span>
        </div>
        <div id="palette-results" class="max-h-72 overflow-y-auto p-1.5 space-y-0.5">
          <!-- Commands get populated dynamically -->
        </div>
      </div>
    </div>

    <!-- Mobile Navigation Drawer -->
    <div id="mobile-drawer" class="fixed inset-0 bg-[#090d16]/95 z-50 transform -translate-x-full transition-transform duration-300 md:hidden flex flex-col">
      <div class="h-11 border-b ide-border px-4 flex items-center justify-between">
        <span class="font-mono text-sm font-bold text-[#94a3b8]">PORTFOLIO FILES</span>
        <button id="mobile-close-btn" class="text-[#94a3b8] hover:text-white p-2">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <nav class="p-6 font-mono text-base space-y-4">
        {isAdmin ? (
          <>
            <a href="/admin#dashboard" class="mobile-nav-link block p-3 rounded bg-[#1e293b] text-[#38bdf8]">
              <span class="text-[#f59e0b]">⌥</span> dashboard.rs
            </a>
            <a href="/admin#projects" class="mobile-nav-link block p-3 rounded hover:bg-[#131b2e] text-[#94a3b8]">
              <span class="text-[#38bdf8]">✏️</span> projects.json
            </a>
            <a href="/admin#skills" class="mobile-nav-link block p-3 rounded hover:bg-[#131b2e] text-[#94a3b8]">
              <span class="text-[#a855f7]">⚙️</span> skills.db
            </a>
            <a href="/admin#status" class="mobile-nav-link block p-3 rounded hover:bg-[#131b2e] text-[#94a3b8]">
              <span class="text-[#10b981]">⚡</span> status.log
            </a>
            <a href="/" class="mobile-nav-link block p-3 text-center border ide-border rounded text-[#38bdf8] mt-6">
              View Portfolio
            </a>
          </>
        ) : (
          <>
            <a href="#hero" class="mobile-nav-link block p-3 rounded bg-[#1e293b] text-[#38bdf8]">
              <span class="text-orange-500">🦀</span> hero.rs
            </a>
            <a href="#about" class="mobile-nav-link block p-3 rounded hover:bg-[#131b2e] text-[#94a3b8]">
              <span class="text-[#a855f7]">🪆</span> about.kt
            </a>
            <a href="#stack" class="mobile-nav-link block p-3 rounded hover:bg-[#131b2e] text-[#94a3b8]">
              <span class="text-yellow-500">⚡</span> stack.json
            </a>
            <a href="#projects" class="mobile-nav-link block p-3 rounded hover:bg-[#131b2e] text-[#94a3b8]">
              <span class="text-[#10b981]">🗄️</span> projects.db
            </a>
            <a href="#contact" class="mobile-nav-link block p-3 rounded hover:bg-[#131b2e] text-[#94a3b8]">
              <span class="text-red-500">🐚</span> contact.sh
            </a>
            <a href="/admin" class="mobile-nav-link block p-3 text-center border ide-border rounded text-[#f472b6] mt-6">
              Admin Login
            </a>
          </>
        )}
      </nav>
    </div>

    <!-- IDE Status Bar (Footer) -->
    <footer class="bg-[#0f1422] border-t ide-border h-6 min-h-6 flex items-center justify-between px-3 text-[11px] font-mono text-[#64748b] select-none z-40">
      <!-- Left side: Branch and Sync Status -->
      <div class="flex items-center space-x-3.5">
        <span class="text-[#38bdf8] flex items-center gap-1 hover:text-white cursor-pointer">
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
          </svg>
          git:main*
        </span>
        <span id="terminal-toggle-btn" class="text-[#10b981] flex items-center gap-1 hover:text-white cursor-pointer select-none">
          <span class="w-1.5 h-1.5 rounded-full bg-[#10b981] inline-block animate-pulse"></span>
          Running Local Dev
        </span>
      </div>

      <!-- Center: Status Messages -->
      <div class="hidden sm:inline-block truncate max-w-sm text-center">
        <span>SQLite v3.45.1 • Node.js {process.version}</span>
      </div>

      <!-- Right side: Editor Info -->
      <div class="flex items-center space-x-3.5">
        <span class="hover:text-white cursor-pointer hidden md:inline-block">UTF-8</span>
        <span class="hover:text-white cursor-pointer">Tab Size: 4</span>
        <span id="ide-clock" class="text-[#94a3b8]">12:00 PM</span>
      </div>
    </footer>

    <!-- Interactive JS for IDE scrolling, mobile sidebar, tab management, terminal, and command palette -->
    <script>
      // 1. Clock Update
      const clockEl = document.getElementById('ide-clock');
      if (clockEl) {
        const updateClock = () => {
          const now = new Date();
          clockEl.innerText = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        };
        updateClock();
        setInterval(updateClock, 60000);
      }

      // 2. Mobile Menu Drawers
      const mobileBtn = document.getElementById('mobile-menu-btn');
      const closeBtn = document.getElementById('mobile-close-btn');
      const drawer = document.getElementById('mobile-drawer');
      const mobileLinks = document.querySelectorAll('.mobile-nav-link');

      const toggleDrawer = () => {
        if (drawer) {
          drawer.classList.toggle('-translate-x-full');
        }
      };

      mobileBtn?.addEventListener('click', toggleDrawer);
      closeBtn?.addEventListener('click', toggleDrawer);
      mobileLinks.forEach(link => {
        link.addEventListener('click', toggleDrawer);
      });

      // 3. Tab closing & Sidebar reopening logic
      const workspace = document.getElementById('editor-workspace');
      const sidebarFiles = document.querySelectorAll('.sidebar-file');
      const tabItems = document.querySelectorAll('.tab-item');
      
      let openFiles = {
        hero: true,
        about: true,
        stack: true,
        projects: true,
        contact: true
      };

      const checkEmptyWorkspace = () => {
        if (!workspace) return;
        const allClosed = Object.values(openFiles).every(v => v === false);
        let emptyMsg = document.getElementById('empty-workspace-message');
        if (allClosed) {
          if (!emptyMsg) {
            emptyMsg = document.createElement('div');
            emptyMsg.id = 'empty-workspace-message';
            emptyMsg.className = 'absolute inset-0 flex flex-col items-center justify-center text-center p-8 bg-[#090d16] font-mono text-sm z-20';
            emptyMsg.innerHTML = `
              <div class="text-slate-600 mb-2">📁 No Editor Tabs Open</div>
              <div class="text-xs text-slate-500 max-w-xs leading-relaxed">Click on any file in the Project Explorer sidebar or press <kbd class="px-1.5 py-0.5 bg-slate-800 border border-slate-700 rounded text-[10px] text-slate-400">Ctrl+P</kbd> to open a file.</div>
            `;
            workspace.appendChild(emptyMsg);
          } else {
            emptyMsg.classList.remove('hidden');
          }
        } else {
          if (emptyMsg) {
            emptyMsg.classList.add('hidden');
          }
        }
      };

      const closeTab = (sectionId) => {
        openFiles[sectionId] = false;
        
        // Hide section
        const sectionEl = document.getElementById(sectionId);
        if (sectionEl) sectionEl.style.display = 'none';
        
        // Hide tab
        const tabEl = document.querySelector(`.tab-item[href="#${sectionId}"]`);
        if (tabEl) (tabEl as HTMLElement).style.display = 'none';
        
        checkEmptyWorkspace();
      };

      const openTab = (sectionId) => {
        openFiles[sectionId] = true;
        
        // Show section
        const sectionEl = document.getElementById(sectionId);
        if (sectionEl) sectionEl.style.display = '';
        
        // Show tab
        const tabEl = document.querySelector(`.tab-item[href="#${sectionId}"]`);
        if (tabEl) (tabEl as HTMLElement).style.display = '';
        
        checkEmptyWorkspace();
        
        // Scroll to target section
        if (sectionEl && workspace) {
          workspace.scrollTo({
            top: sectionEl.offsetTop - 5,
            behavior: 'smooth'
          });
        }
      };

      // Register close tab events
      document.querySelectorAll('.tab-close').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          const sectionId = btn.getAttribute('data-section');
          if (sectionId) closeTab(sectionId);
        });
      });

      // Register file clicks to open/scroll
      sidebarFiles.forEach(file => {
        file.addEventListener('click', (e) => {
          const href = file.getAttribute('href');
          if (href && href.startsWith('#')) {
            e.preventDefault();
            const sectionId = href.substring(1);
            openTab(sectionId);
          }
        });
      });

      // 4. Scroll Sync for Tabs and Sidebar files (only if not admin)
      const isPageAdmin = window.location.pathname.startsWith('/admin');
      if (!isPageAdmin && workspace) {
        const sections = ['hero', 'about', 'stack', 'projects', 'contact'];

        const activeClasses = ['bg-[#1e293b]', 'text-[#38bdf8]', 'border-l-2', 'border-[#38bdf8]'];
        const inactiveClasses = ['hover:bg-[#1a2333]', 'text-[#94a3b8]', 'border-l-2', 'border-transparent'];
        const activeTabClasses = ['bg-[#090d16]', 'border-[#38bdf8]'];
        const inactiveTabClasses = ['bg-[#0d121f]', 'border-transparent', 'text-[#64748b]'];

        const handleScroll = () => {
          let currentSection = 'hero';
          const scrollPos = workspace.scrollTop + 120; // offset for tab bar

          for (const section of sections) {
            const el = document.getElementById(section);
            if (el && openFiles[section]) {
              const top = el.offsetTop;
              const height = el.offsetHeight;
              if (scrollPos >= top && scrollPos < top + height) {
                currentSection = section;
                break;
              }
            }
          }

          // Update Sidebar highlight
          sidebarFiles.forEach((file) => {
            const href = file.getAttribute('href');
            if (href === `#${currentSection}`) {
              file.classList.add(...activeClasses);
              file.classList.remove(...inactiveClasses);
            } else {
              file.classList.remove(...activeClasses);
              file.classList.add(...inactiveClasses);
            }
          });

          // Update Tab highlights
          tabItems.forEach((tab) => {
            const href = tab.getAttribute('href');
            if (href === `#${currentSection}`) {
              tab.classList.add(...activeTabClasses);
              tab.classList.remove(...inactiveTabClasses);
              tab.classList.add('text-[#e2e8f0]');
            } else {
              tab.classList.remove(...activeTabClasses);
              tab.classList.add(...inactiveTabClasses);
              tab.classList.remove('text-[#e2e8f0]');
            }
          });
        };

        // Scroll listener on workspace
        workspace.addEventListener('scroll', handleScroll);

        // Sidebar click scroll handler
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
          anchor.addEventListener('click', function (e) {
            e.preventDefault();
            const targetId = this.getAttribute('href')?.substring(1);
            if (targetId) openTab(targetId);
          });
        });
      }

      // 5. Collapsible Terminal Panel
      const terminalPanel = document.getElementById('ide-terminal-panel');
      const terminalToggleBtn = document.getElementById('terminal-toggle-btn');
      const closeTerminalBtn = document.getElementById('close-terminal-btn');

      const toggleTerminal = () => {
        terminalPanel?.classList.toggle('hidden');
      };

      terminalToggleBtn?.addEventListener('click', toggleTerminal);
      closeTerminalBtn?.addEventListener('click', () => {
        terminalPanel?.classList.add('hidden');
      });

      // 6. Command Palette Control
      const palette = document.getElementById('command-palette');
      const paletteInput = document.getElementById('palette-search') as HTMLInputElement | null;
      const paletteResults = document.getElementById('palette-results');
      const paletteTrigger = document.getElementById('palette-trigger');

      const commands = [
        { name: 'Go to hero.rs (Hero Area)', action: () => openTab('hero') },
        { name: 'Go to about.kt (About & Bio)', action: () => openTab('about') },
        { name: 'Go to stack.json (Tech Grid)', action: () => openTab('stack') },
        { name: 'Go to projects.db (Featured Projects)', action: () => openTab('projects') },
        { name: 'Go to contact.sh (Connect Link)', action: () => openTab('contact') },
        { name: 'Open admin_dashboard.rs', action: () => window.location.href = '/admin' },
        { name: 'Toggle File Explorer Sidebar', action: () => document.getElementById('ide-sidebar')?.classList.toggle('hidden') },
        { name: 'Toggle Bottom Terminal Panel', action: () => toggleTerminal() }
      ];

      let activeIndex = 0;
      let filteredCommands = [...commands];

      const showPalette = () => {
        palette?.classList.remove('hidden');
        if (paletteInput) {
          paletteInput.focus();
          paletteInput.value = '';
        }
        filteredCommands = [...commands];
        activeIndex = 0;
        renderResults();
      };

      const hidePalette = () => {
        palette?.classList.add('hidden');
      };

      const renderResults = () => {
        if (!paletteResults) return;
        paletteResults.innerHTML = '';

        if (filteredCommands.length === 0) {
          paletteResults.innerHTML = '<div class="px-3 py-2 text-slate-500 font-mono text-xs">No matching files or commands.</div>';
          return;
        }

        filteredCommands.forEach((cmd, idx) => {
          const div = document.createElement('div');
          div.className = `px-3 py-2 rounded cursor-pointer select-none text-xs font-mono transition-all ${idx === activeIndex ? 'bg-[#1e293b] text-[#38bdf8] font-bold' : 'text-slate-400 hover:bg-[#131b2e] hover:text-slate-200'}`;
          div.innerText = cmd.name;
          div.addEventListener('click', () => {
            cmd.action();
            hidePalette();
          });
          paletteResults.appendChild(div);
        });
      };

      paletteTrigger?.addEventListener('click', showPalette);

      window.addEventListener('keydown', (e) => {
        if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'p') {
          e.preventDefault();
          showPalette();
        }
        if (e.key === 'Escape') {
          hidePalette();
        }
      });

      paletteInput?.addEventListener('input', (e) => {
        const query = (e.target as HTMLInputElement).value.toLowerCase();
        filteredCommands = commands.filter(c => c.name.toLowerCase().includes(query));
        activeIndex = 0;
        renderResults();
      });

      paletteInput?.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          activeIndex = (activeIndex + 1) % filteredCommands.length;
          renderResults();
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          activeIndex = (activeIndex - 1 + filteredCommands.length) % filteredCommands.length;
          renderResults();
        } else if (e.key === 'Enter') {
          e.preventDefault();
          if (filteredCommands[activeIndex]) {
            filteredCommands[activeIndex].action();
            hidePalette();
          }
        }
      });
    </script>
  </body>
</html>
