<!-- Client side Javascript for toggling forms and editing projects dynamically -->
<script>
  // 1. Add/Edit Project Form Toggle
  const toggleProjFormBtn = document.getElementById('toggle-project-form-btn');
  const cancelProjFormBtn = document.getElementById('cancel-project-form-btn');
  const projFormContainer = document.getElementById('project-form-container');
  const projMutForm = document.getElementById('project-mut-form') as HTMLFormElement;
  const formTitle = document.getElementById('form-title');
  const actionField = document.getElementById('project-action-field') as HTMLInputElement;
  const idField = document.getElementById('project-id-field') as HTMLInputElement;

  // Input fields
  const pTitle = document.getElementById('p-title') as HTMLInputElement;
  const pTags = document.getElementById('p-tags') as HTMLInputElement;
  const pDesc = document.getElementById('p-desc') as HTMLTextAreaElement;
  const pGithub = document.getElementById('p-github') as HTMLInputElement;
  const pLive = document.getElementById('p-live') as HTMLInputElement;

  const showProjectForm = (isEdit = false) => {
    projFormContainer?.classList.remove('hidden');
    if (!isEdit) {
      // Clear inputs for new project addition
      if (projMutForm) projMutForm.reset();
      if (actionField) actionField.value = 'add_project';
      if (idField) idField.value = '';
      if (formTitle) formTitle.innerText = '// Add Project File';
    }
  };

  const hideProjectForm = () => {
    projFormContainer?.classList.add('hidden');
    if (projMutForm) projMutForm.reset();
  };

  toggleProjFormBtn?.addEventListener('click', () => showProjectForm(false));
  cancelProjFormBtn?.addEventListener('click', hideProjectForm);

  // Bind edit buttons to populate form
  const editButtons = document.querySelectorAll('.edit-project-btn');
  editButtons.forEach(btn => {
    btn.addEventListener('click', (e) => {
      const target = e.currentTarget as HTMLButtonElement;
      
      const id = target.getAttribute('data-id') || '';
      const title = target.getAttribute('data-title') || '';
      const desc = target.getAttribute('data-desc') || '';
      const tags = target.getAttribute('data-tags') || '';
      const github = target.getAttribute('data-github') || '';
      const live = target.getAttribute('data-live') || '';

      // Populate form fields
      if (idField) idField.value = id;
      if (pTitle) pTitle.value = title;
      if (pDesc) pDesc.value = desc;
      if (pTags) pTags.value = tags;
      if (pGithub) pGithub.value = github;
      if (pLive) pLive.value = live;

      // Switch mode to edit
      if (actionField) actionField.value = 'edit_project';
      if (formTitle) formTitle.innerText = `// Edit Project: ${title}`;
      
      showProjectForm(true);
      
      // Scroll to form
      projFormContainer?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
  });

  // 2. Skill Form Toggle
  const toggleSkillFormBtn = document.getElementById('toggle-skill-form-btn');
  const cancelSkillFormBtn = document.getElementById('cancel-skill-form-btn');
  const skillFormContainer = document.getElementById('skill-form-container');

  toggleSkillFormBtn?.addEventListener('click', () => {
    skillFormContainer?.classList.remove('hidden');
  });
  cancelSkillFormBtn?.addEventListener('click', () => {
    skillFormContainer?.classList.add('hidden');
  });

  // 3. Tab Switching
  const btnTabContent = document.getElementById('btn-tab-content');
  const btnTabProfile = document.getElementById('btn-tab-profile');
  const paneContent = document.getElementById('pane-content');
  const paneProfile = document.getElementById('pane-profile');

  btnTabContent?.addEventListener('click', () => {
    paneContent?.classList.remove('hidden');
    paneProfile?.classList.add('hidden');

    btnTabContent.classList.add('bg-[#0c1222]', 'text-sky-400', 'border-b-sky-500');
    btnTabContent.classList.remove('text-slate-500');
    btnTabProfile?.classList.remove('bg-[#0c1222]', 'text-sky-400', 'border-b-sky-500');
    btnTabProfile?.classList.add('text-slate-500');
  });

  btnTabProfile?.addEventListener('click', () => {
    paneProfile?.classList.remove('hidden');
    paneContent?.classList.add('hidden');

    btnTabProfile.classList.add('bg-[#0c1222]', 'text-sky-400', 'border-b-sky-500');
    btnTabProfile.classList.remove('text-slate-500');
    btnTabContent?.classList.remove('bg-[#0c1222]', 'text-sky-400', 'border-b-sky-500');
    btnTabContent?.classList.add('text-slate-500');
  });
</script>
