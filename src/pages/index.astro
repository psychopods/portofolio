---
import Layout from '../layouts/Layout.astro';
import db from '../lib/db';

// Force dynamic execution (SSR)
export const prerender = false;

// Query projects from database
let projects = [];
let systemsSkills = [];
let crossPlatformSkills = [];
let backendWebSkills = [];
let currentStatus = "Optimizing system performance.";
let s = {
  dev_name: 'Paschal Joseph',
  dev_role: 'Systems Architect & Developer',
  dev_languages: 'Rust, Kotlin, Python, Java, SQL',
  dev_focus: 'Rust Core logic & Kotlin Multiplatform',
  hero_title: 'Systems Architect & Cross-Platform Developer',
  hero_description: 'Systems-focused software developer specializing in Rust core logic and Kotlin Multiplatform (KMP). Experienced in building high-performance backend telemetry services, distributed database systems, and serial port hardware integrations.',
  about_title: '01. Technical Mindset',
  about_description_1: 'I design software with a focus on resource constraints and execution runtime efficiency. Whether hacking on Rust memory allocations, optimizing an OpenGL vertex buffer, or building a local database schema with SQLite, my philosophy remains the same: pragmatic, structured, and fast.',
  about_description_2: 'Having worked across low-level architectures and high-level client applications, I specialize in bridging the gap. I build offline-first desktop and mobile tools using Compose Multiplatform and Kotlin Coroutines, ensuring fluid performance even without network dependency.',
  about_description_3: 'I thrive on learning and adapting. I view programming languages as tools to model systems—picking up a new API surface or architecture is part of the engineering loop.',
  about_philosophy: 'Build local-first, compile static, optimize everything.',
  contact_email: 'paschaltimoth@gmx.us',
  contact_github: 'github.com/psychopods',
  contact_linkedin: 'linkedin.com/in/paschaltimoth',
  contact_resume_link: '/Paschal_Joseph_Resume.odt',
  contact_description: 'Interested in starting a project, collaborating on compilers, or looking for a polyglot engineer to reinforce your systems/client pipelines? Let\'s connect through the shell block on the right or reach out directly.',
  bento_systems_desc: 'Writing memory-safe code, raw OS interactions, native performance, and targeted WASM compiler systems.',
  bento_crossplatform_desc: 'Designing elegant application structures, offline-first client syncing, and multi-runtime desktop/mobile apps.',
  bento_backendweb_desc: 'Structuring hyper-fast server-side endpoints, microservices, local storage configurations, and database query layers.'
};

try {
  const projectRows = db.prepare('SELECT * FROM projects ORDER BY order_index ASC').all() as any[];
  projects = projectRows.map(p => ({
    ...p,
    tech_tags: JSON.parse(p.tech_tags)
  }));

  const skillRows = db.prepare('SELECT * FROM skills WHERE is_active = 1 ORDER BY order_index ASC').all() as any[];
  systemsSkills = skillRows.filter(sk => sk.category === 'systems');
  crossPlatformSkills = skillRows.filter(sk => sk.category === 'cross-platform');
  backendWebSkills = skillRows.filter(sk => sk.category === 'backend-web');

  const statusRow = db.prepare('SELECT * FROM status_update ORDER BY id DESC LIMIT 1').get() as any;
  if (statusRow) {
    currentStatus = statusRow.status;
  }

  const settingsRows = db.prepare('SELECT * FROM portfolio_settings').all() as { key: string, value: string }[];
  settingsRows.forEach(row => {
    if (row.key in s) {
      s[row.key as keyof typeof s] = row.value;
    }
  });
} catch (err) {
  console.error("Database query error:", err);
}

const langArray = s.dev_languages.split(',').map(l => l.trim()).filter(Boolean);
const langString = langArray.map(l => `"${l}"`).join(', ');
const linkToUrl = (value: string) => {
  const trimmed = value.trim();
  if (!trimmed) return '#';
  return /^https?:\/\//i.test(trimmed) ? trimmed : `https://${trimmed}`;
};
const githubUrl = linkToUrl(s.contact_github);
const linkedinUrl = linkToUrl(s.contact_linkedin);
const gitUser = s.contact_github.replace(/^(https?:\/\/)?(www\.)?github\.com\//i, '').split('/')[0] || 'psychopods';
const apiPingUrl = `https://api.${gitUser}.dev/v1/ping`;
---

<Layout>
  <!-- Page 1: Public Portfolio (Interactive IDE Workspace) -->
  <div class="w-full max-w-5xl mx-auto px-4 md:px-8 py-10 space-y-24 pb-24 select-text">
    
    <!-- SECTION 1: HERO (hero.rs) -->
    <section id="hero" class="relative pt-6">
      <!-- File header comment -->
      <div class="font-mono text-xs text-[#475569] mb-4 flex items-center gap-2">
        <span>// File: src/portfolio/hero.rs</span>
        <span class="h-px bg-slate-800 flex-grow"></span>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        <!-- Rust Code representation of Hero -->
        <div class="order-2 lg:order-1 lg:col-span-5 bg-[#0a0e17] border ide-border rounded-lg p-5 font-mono text-xs shadow-2xl glass-panel">
          <div class="flex justify-between items-center border-b border-slate-800/60 pb-2 mb-3">
            <span class="text-[#64748b]">cargo-run-output</span>
            <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
          </div>
          <div class="space-y-1 text-[#e2e8f0]">
            <p class="text-[#64748b]">$ cargo run --quiet</p>
            <p class="text-amber-400 font-bold">▶ Launching Portfolio Core...</p>
            <div class="pl-2 pt-2 border-l border-slate-800 space-y-1">
              <p><span class="text-orange-400 font-bold">struct</span> <span class="text-sky-400">Developer</span> &#123;</p>
              <p class="pl-4">name: <span class="text-emerald-400">"{s.dev_name}"</span>,</p>
              <p class="pl-4">role: <span class="text-emerald-400">"{s.dev_role}"</span>,</p>
              <p class="pl-4">languages: <span class="text-purple-400">vec!</span>[{langString}],</p>
              <p class="pl-4">focus: <span class="text-emerald-400">"{s.dev_focus}"</span></p>
              <p>&#125;</p>
            </div>
            <p class="text-slate-500 pt-2">// Active compiler thread initialized</p>
          </div>
        </div>

        <!-- Rendered Hero content -->
        <div class="order-1 lg:order-2 lg:col-span-7 space-y-6">
          <!-- Live Status Badge -->
          <div class="inline-flex items-center gap-2 bg-[#10b981]/10 border border-[#10b981]/20 px-3 py-1.5 rounded-full text-xs font-mono text-[#10b981]">
            <span class="w-2 h-2 rounded-full bg-[#10b981] animate-ping"></span>
            <span>CURRENTLY CODING:</span>
            <span class="text-slate-300 font-semibold">{currentStatus}</span>
          </div>

          <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight font-sans text-transparent bg-clip-text bg-gradient-to-r from-sky-400 via-indigo-200 to-purple-400 leading-tight">
            {s.hero_title}
          </h1>
          
          <p class="text-base text-slate-400 leading-relaxed max-w-xl">
            {s.hero_description}
          </p>

          <div class="flex flex-wrap gap-4 pt-2">
            <a href="#projects" class="px-5 py-2.5 rounded bg-sky-500 hover:bg-sky-400 text-slate-900 font-medium font-mono text-sm transition-all duration-200 shadow-lg shadow-sky-500/10 flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 13l-7 7-7-7m14-6l-7 7-7-7" />
              </svg>
              Explore Projects
            </a>
            <a href="#contact" class="px-5 py-2.5 rounded border ide-border hover:bg-[#1a2333]/50 text-slate-300 hover:text-white font-mono text-sm transition-all duration-200">
              $ ./contact.sh
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION 2: ABOUT (about.kt) -->
    <section id="about" class="relative pt-6">
      <div class="font-mono text-xs text-[#475569] mb-4 flex items-center gap-2">
        <span>// File: src/portfolio/about.kt</span>
        <span class="h-px bg-slate-800 flex-grow"></span>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        <div class="lg:col-span-7 space-y-6">
          <h2 class="text-2xl md:text-3xl font-bold font-sans text-slate-100 flex items-center gap-3">
            <span class="text-[#a855f7] font-mono">01.</span> {s.about_title.replace(/^01\.\s*/, '')}
          </h2>
          <div class="space-y-4 text-slate-400 text-sm md:text-base leading-relaxed">
            <p>
              {s.about_description_1}
            </p>
            <p>
              {s.about_description_2}
            </p>
            <p>
              {s.about_description_3}
            </p>
          </div>
        </div>

        <!-- Kotlin Code presentation of About -->
        <div class="lg:col-span-5 bg-[#0a0e17] border ide-border rounded-lg p-5 font-mono text-xs shadow-2xl glass-panel">
          <div class="flex justify-between items-center border-b border-slate-800/60 pb-2 mb-3">
            <span class="text-[#64748b]">editor_kt</span>
            <span class="text-purple-400 text-[10px]">Kotlin</span>
          </div>
          <div class="space-y-1 text-[#a855f7]">
            <p><span class="text-orange-400">package</span> <span class="text-slate-300">portfolio</span></p>
            <p class="text-slate-500">// Mindset model</p>
            <p><span class="text-orange-400">class</span> <span class="text-sky-400">Engineer</span>(</p>
            <p class="pl-4">val name: String = <span class="text-emerald-400">"{s.dev_name}"</span></p>
            <p>) &#123;</p>
            <p class="pl-4 text-[#e2e8f0]"><span class="text-orange-400">fun</span> <span class="text-blue-400">getPhilosophy</span>() = <span class="text-[#64748b]">&#123;</span></p>
            <p class="pl-8 text-emerald-400">"{s.about_philosophy}"</p>
            <p class="pl-4 text-[#e2e8f0]">&#125;</p>
            <p class="pl-4 text-[#e2e8f0]"><span class="text-orange-400">fun</span> <span class="text-blue-400">canAdaptToStack</span>(stack: String) = <span class="text-orange-400">true</span></p>
            <p>&#125;</p>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION 3: THE STACK (stack.json) -->
    <section id="stack" class="relative pt-6">
      <div class="font-mono text-xs text-[#475569] mb-4 flex items-center gap-2">
        <span>// File: src/portfolio/stack.json</span>
        <span class="h-px bg-slate-800 flex-grow"></span>
      </div>

      <div class="space-y-8">
        <h2 class="text-2xl md:text-3xl font-bold font-sans text-slate-100 flex items-center gap-3">
          <span class="text-yellow-500 font-mono">02.</span> Bento Stack Grid
        </h2>

        <!-- Bento Grid Layout -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          
          <!-- Category 1: Low-Level & Systems -->
          <div class="bg-[#0c1222] border border-orange-500/20 hover:border-orange-500/40 rounded-xl p-6 transition-all duration-300 shadow-lg hover:shadow-orange-500/5 group flex flex-col justify-between">
            <div>
              <div class="flex justify-between items-center mb-4">
                <h3 class="text-lg font-bold font-mono text-orange-400">Low-Level & Systems</h3>
                <span class="text-xs font-mono text-orange-300/70 border border-orange-500/20 rounded px-2 py-1 group-hover:text-orange-200 transition-colors">sys</span>
              </div>
              <p class="text-slate-400 text-xs font-mono mb-4 leading-relaxed">
                {s.bento_systems_desc}
              </p>
            </div>
            
            <div class="flex flex-wrap gap-2 pt-2">
              {systemsSkills.length > 0 ? (
                systemsSkills.map(s => (
                  <span class="px-2.5 py-1 bg-orange-500/10 border border-orange-500/20 rounded font-mono text-xs text-orange-300">
                    {s.name}
                  </span>
                ))
              ) : (
                <>
                  <span class="px-2.5 py-1 bg-orange-500/10 border border-orange-500/20 rounded font-mono text-xs text-orange-300">Rust</span>
                  <span class="px-2.5 py-1 bg-orange-500/10 border border-orange-500/20 rounded font-mono text-xs text-orange-300">C++</span>
                  <span class="px-2.5 py-1 bg-orange-500/10 border border-orange-500/20 rounded font-mono text-xs text-orange-300">WebAssembly</span>
                </>
              )}
            </div>
          </div>

          <!-- Category 2: Cross-Platform & Mobile -->
          <div class="bg-[#0c1222] border border-purple-500/20 hover:border-purple-500/40 rounded-xl p-6 transition-all duration-300 shadow-lg hover:shadow-purple-500/5 group flex flex-col justify-between">
            <div>
              <div class="flex justify-between items-center mb-4">
                <h3 class="text-lg font-bold font-mono text-purple-400">Cross-Platform & Mobile</h3>
                <span class="text-xs font-mono text-purple-300/70 border border-purple-500/20 rounded px-2 py-1 group-hover:text-purple-200 transition-colors">app</span>
              </div>
              <p class="text-slate-400 text-xs font-mono mb-4 leading-relaxed">
                {s.bento_crossplatform_desc}
              </p>
            </div>
            
            <div class="flex flex-wrap gap-2 pt-2">
              {crossPlatformSkills.length > 0 ? (
                crossPlatformSkills.map(s => (
                  <span class="px-2.5 py-1 bg-purple-500/10 border border-purple-500/20 rounded font-mono text-xs text-purple-300">
                    {s.name}
                  </span>
                ))
              ) : (
                <>
                  <span class="px-2.5 py-1 bg-purple-500/10 border border-purple-500/20 rounded font-mono text-xs text-purple-300">Kotlin</span>
                  <span class="px-2.5 py-1 bg-purple-500/10 border border-purple-500/20 rounded font-mono text-xs text-purple-300">Compose MP</span>
                  <span class="px-2.5 py-1 bg-purple-500/10 border border-purple-500/20 rounded font-mono text-xs text-purple-300">Android SDK</span>
                </>
              )}
            </div>
          </div>

          <!-- Category 3: Backend & Web Technologies -->
          <div class="bg-[#0c1222] border border-emerald-500/20 hover:border-emerald-500/40 rounded-xl p-6 transition-all duration-300 shadow-lg hover:shadow-emerald-500/5 group flex flex-col justify-between">
            <div>
              <div class="flex justify-between items-center mb-4">
                <h3 class="text-lg font-bold font-mono text-emerald-400">Backend & Web</h3>
                <span class="text-xs font-mono text-emerald-300/70 border border-emerald-500/20 rounded px-2 py-1 group-hover:text-emerald-200 transition-colors">api</span>
              </div>
              <p class="text-slate-400 text-xs font-mono mb-4 leading-relaxed">
                {s.bento_backendweb_desc}
              </p>
            </div>
            
            <div class="flex flex-wrap gap-2 pt-2">
              {backendWebSkills.length > 0 ? (
                backendWebSkills.map(s => (
                  <span class="px-2.5 py-1 bg-emerald-500/10 border border-emerald-500/20 rounded font-mono text-xs text-emerald-300">
                    {s.name}
                  </span>
                ))
              ) : (
                <>
                  <span class="px-2.5 py-1 bg-emerald-500/10 border border-emerald-500/20 rounded font-mono text-xs text-emerald-300">Node.js</span>
                  <span class="px-2.5 py-1 bg-emerald-500/10 border border-emerald-500/20 rounded font-mono text-xs text-emerald-300">SQLite</span>
                  <span class="px-2.5 py-1 bg-emerald-500/10 border border-emerald-500/20 rounded font-mono text-xs text-emerald-300">Astro</span>
                </>
              )}
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- SECTION 4: PROJECTS (projects.db) -->
    <section id="projects" class="relative pt-6">
      <div class="font-mono text-xs text-[#475569] mb-4 flex items-center gap-2">
        <span>// File: src/portfolio/projects.db</span>
        <span class="h-px bg-slate-800 flex-grow"></span>
      </div>

      <div class="space-y-8">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
          <div>
            <h2 class="text-2xl md:text-3xl font-bold font-sans text-slate-100 flex items-center gap-3">
              <span class="text-[#10b981] font-mono">03.</span> Featured Projects
            </h2>
            <p class="text-slate-400 text-sm mt-2 max-w-lg">
              Below are active codebases queried directly from the portfolio database system.
            </p>
          </div>
          <div class="font-mono text-xs text-[#64748b] bg-[#0c1222] border ide-border rounded px-3 py-1.5 self-start md:self-auto">
            <span class="text-emerald-400">SELECT</span> * <span class="text-emerald-400">FROM</span> projects <span class="text-emerald-400">ORDER BY</span> order_index;
          </div>
        </div>

        <!-- Projects Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {projects.length > 0 ? projects.map((project, index) => (
            <div class="bg-[#0c1222]/80 border border-slate-800/80 hover:border-sky-500/30 rounded-xl p-6 transition-all duration-300 flex flex-col justify-between shadow-xl hover:shadow-sky-500/5 group relative overflow-hidden">
              
              <!-- Background card index decoration -->
              <div class="absolute -top-6 -right-6 text-7xl font-mono font-black text-slate-900 select-none opacity-40 pointer-events-none group-hover:text-slate-800/80 transition-colors">
                {String(index + 1).padStart(2, '0')}
              </div>

              <div class="space-y-4 relative z-10">
                <div class="flex items-center justify-between">
                  <h3 class="text-xl font-bold text-slate-200 group-hover:text-sky-400 transition-colors">
                    {project.title}
                  </h3>
                  <div class="flex items-center space-x-2.5">
                    {project.github_link && (
                      <a href={project.github_link} target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-white p-1 hover:bg-slate-800/60 rounded transition-all" title="View Source Code">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                          <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.577.688.479C19.138 20.162 22 16.418 22 12c0-5.523-4.477-10-10-10z" clip-rule="evenodd" />
                        </svg>
                      </a>
                    )}
                    {project.live_link && (
                      <a href={project.live_link} target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-[#10b981] p-1 hover:bg-slate-800/60 rounded transition-all" title="View Live Demo">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                        </svg>
                      </a>
                    )}
                  </div>
                </div>

                <p class="text-slate-400 text-sm leading-relaxed min-h-[60px]">
                  {project.description}
                </p>
              </div>

              <!-- Tech Tags footer of card -->
              <div class="flex flex-wrap gap-1.5 pt-4 border-t border-slate-800/60 mt-4 relative z-10">
                {project.tech_tags.map(tag => (
                  <span class="px-2 py-0.5 bg-[#090d16] border border-slate-800 rounded font-mono text-[10px] text-sky-400/80">
                    {tag}
                  </span>
                ))}
              </div>

            </div>
          )) : (
            <div class="md:col-span-2 bg-[#0c1222]/80 border border-dashed border-slate-700 rounded-xl p-8 text-center">
              <p class="font-mono text-sm text-slate-300">No featured projects are published yet.</p>
              <p class="text-slate-500 text-sm mt-2">Add projects from the admin workspace to populate this section.</p>
            </div>
          )}
        </div>
      </div>
    </section>

    <!-- SECTION 5: CONTACT (contact.sh) -->
    <section id="contact" class="relative pt-6">
      <div class="font-mono text-xs text-[#475569] mb-4 flex items-center gap-2">
        <span>// File: src/portfolio/contact.sh</span>
        <span class="h-px bg-slate-800 flex-grow"></span>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
        <div class="lg:col-span-7 space-y-6">
          <h2 class="text-2xl md:text-3xl font-bold font-sans text-slate-100 flex items-center gap-3">
            <span class="text-red-500 font-mono">04.</span> Establish Hook
          </h2>
          <p class="text-slate-400 text-sm md:text-base leading-relaxed">
            {s.contact_description}
          </p>

          <!-- Contact items list -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-2">
            <a href={`mailto:${s.contact_email}`} class="flex items-center gap-3 bg-[#0c1222] border ide-border hover:border-slate-700 p-3.5 rounded-lg text-sm font-mono text-slate-300 hover:text-white transition-all group">
              <span class="text-red-500 group-hover:scale-110 transition-transform">✉</span>
              <span>{s.contact_email}</span>
            </a>
            <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 bg-[#0c1222] border ide-border hover:border-slate-700 p-3.5 rounded-lg text-sm font-mono text-slate-300 hover:text-white transition-all group">
              <span class="text-orange-500 group-hover:scale-110 transition-transform">git</span>
              <span>{s.contact_github}</span>
            </a>
            <a href={linkedinUrl} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 bg-[#0c1222] border ide-border hover:border-slate-700 p-3.5 rounded-lg text-sm font-mono text-slate-300 hover:text-white transition-all group">
              <span class="text-sky-400 group-hover:scale-110 transition-transform">⌘</span>
              <span>{s.contact_linkedin}</span>
            </a>
            <a href={s.contact_resume_link} class="flex items-center gap-3 bg-sky-500/10 border border-sky-500/20 hover:border-sky-500/40 p-3.5 rounded-lg text-sm font-mono text-sky-300 hover:text-sky-200 transition-all group" download>
              <span class="text-sky-400 group-hover:animate-bounce">↓</span>
              <span>Download Resume (ODT)</span>
            </a>
          </div>
        </div>

        <!-- Bash shell representation of Contact -->
        <div class="lg:col-span-5 bg-[#0a0e17] border ide-border rounded-lg p-5 font-mono text-xs shadow-2xl glass-panel">
          <div class="flex justify-between items-center border-b border-slate-800/60 pb-2 mb-3">
            <span class="text-[#64748b]">bash_terminal</span>
            <span class="text-red-400 text-[10px]">sh</span>
          </div>
